## 1. Exercising Tuples

```python
# 1a) Take five inputs from a user and save it in a tuple called my_tuple

# Create a temporary list to store inputs
temp_list = []

# Ask the user for 5 inputs
for i in range(5):
    user_input = input(f"Enter value {i+1}: ")
    temp_list.append(user_input)

# Convert list to a tuple
my_tuple = tuple(temp_list)

# Print the tuple
print("Your tuple is:", my_tuple)

# 1b) How do you assign a single element in a tuple?

# Tuples are immutable, so you cannot change a single element after it is created
x = (1,2,3,4)
# x[1] = 5        # Not allowed
# x.append(1)     # Not allowed
# del x[2]        # Not allowed

# 1c) Count the repeated integers in a tuple

count_tuple = (1,2,3,4,3,2,1,2,3,5,4,3,2,1)

print("Count of 1:", count_tuple.count(1))
print("Count of 2:", count_tuple.count(2))
print("Count of 3:", count_tuple.count(3))
print("Count of 4:", count_tuple.count(4))
print("Count of 5:", count_tuple.count(5))

# 1d) Concatenate the tuple with itself and prove they are different

doubled_tuple = count_tuple + count_tuple

print("Original tuple:", count_tuple)
print("Doubled tuple:", doubled_tuple)

# Proof by length
print("Length of original:", len(count_tuple))
print("Length of doubled:", len(doubled_tuple))


# 3. Memory Management

my_x = [100, 200, 300, 400]   # List
my_y = (200, 300, 400, 500)   # Tuple

# Lists (my_x):
# - Mutable: elements can be changed after creation.
# - Each element has its own memory address.
# - If we change one element, Python assigns a new address to that element, but the other elements usually stay the same.
# - Example: my_x[0] = 999 would change only the first element's address.

# Tuples (my_y):
# - Immutable: elements cannot change.
# - Python often keeps the same memory address for each element because nothing will change.
# - Tuples are slightly more memory-efficient than lists.

# Optional demo to see memory addresses in Python
print("List element addresses:")
for i, val in enumerate(my_x):
    print(f"my_x[{i}] -> {id(val)}")

print("\nTuple element addresses:")
for i, val in enumerate(my_y):
    print(f"my_y[{i}] -> {id(val)}")

# Summary table in comments:
# Index | my_x (list)                  | my_y (tuple)
# 0     | Address can change           | Fixed address
# 1     | Address can change           | Fixed address
# 2     | Address can change           | Fixed address
# 3     | Address can change           | Fixed address


